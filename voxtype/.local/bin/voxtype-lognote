#!/bin/bash
TEXT=$(cat)
[ -z "$TEXT" ] && exit 0

FILE="$HOME/notes/00-Organization/vnotes.md"
mkdir -p "$(dirname "$FILE")"

# Format: 2026-04-12T12:12:13 - Transcription
printf "%s - %s\n" "$(date +%FT%T)" "$TEXT" >> "$FILE"

# Ensure the notification can reach your desktop session
export DBUS_SESSION_BUS_ADDRESS="unix:path=/run/user/$(id -u)/bus"
notify-send "Voxtype" "Note logged to vnotes.md"

# Output the text so voxtype considers the post-processing successful
printf "%s" "$TEXT"
exit 0
