#!/bin/bash
set -euo pipefail

# Security Guard: Prevent running in the user's base home directory
if [[ "$PWD" == "$HOME" ]]; then
    echo "Error: Running opencode in your HOME directory is forbidden for security reasons." >&2
    echo "Please run it from within a specific project directory." >&2
    exit 1
fi

# Ensure a persistent volume for the container's home (caches, state, etc.)
# This keeps the container writable without exposing the host's actual $HOME.
docker volume create opencode-home-cache >/dev/null

# Internal container paths
INT_HOME="/home/node"

# Ensure plugins are discovered by opencode-ai
# We link the global npm plugins into the user's local node_modules in the persistent volume.
docker run --rm -u "$(id -u):$(id -g)" -v opencode-home-cache:"$INT_HOME" --entrypoint bash opencode-sandbox:latest -c "mkdir -p \"$INT_HOME/node_modules\" && ln -sf /usr/local/lib/node_modules/opencode-*-auth \"$INT_HOME/node_modules/\""

# Determine the dotfiles repo location (resolving symlinks)
SCRIPT_PATH=$(readlink -f "${BASH_SOURCE[0]}")
DOTFILES_DIR=$(cd -- "$(dirname -- "$SCRIPT_PATH")/../../.." &>/dev/null && pwd)

# Ensure interactive mode if running in a terminal
DOCKER_FLAGS=("-i")
if [ -t 0 ]; then
    DOCKER_FLAGS+=("-t")
fi

# Map common git configs (Read-Only)
if [ -f "$HOME/.gitconfig" ]; then
    DOCKER_FLAGS+=("-v" "$HOME/.gitconfig:$INT_HOME/.gitconfig:ro")
fi

# Ensure opencode config is available (Read-Write)
# We mount the directory, and also the dotfiles repo so symlinks resolve.
if [ -d "$HOME/.config/opencode" ]; then
    DOCKER_FLAGS+=("-v" "$HOME/.config/opencode:$INT_HOME/.config/opencode:rw")
    DOCKER_FLAGS+=("-v" "$DOTFILES_DIR:$INT_HOME/.dotfiles:ro")
fi

# Execute opencode inside docker container
# -u matches current user to avoid permission issues
# -e HOME="$INT_HOME" tells the tool to use the isolated volume home
# -v opencode-home-cache:"$INT_HOME" isolates the container's home
# -v "$PWD":"$PWD" -w "$PWD" mounts only the current project directory
# --add-host allows connecting to local services (e.g., ollama) via host.docker.internal
# --tmpfs /tmp:exec ensures a clean, in-memory /tmp with execution permissions
# --security-opt=no-new-privileges:true --cap-drop=ALL harden the container

exec docker run \
    --rm \
    "${DOCKER_FLAGS[@]}" \
    -u "$(id -u):$(id -g)" \
    -e HOME="$INT_HOME" \
    -e USER="node" \
    -e NODE_PATH="/usr/local/lib/node_modules" \
    -e GOOGLE_GENERATIVE_AI_API_KEY="${GOOGLE_GENERATIVE_AI_API_KEY:-}" \
    -e ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-}" \
    -v opencode-home-cache:"$INT_HOME" \
    -v "$PWD":"$PWD" \
    -w "$PWD" \
    --add-host=host.docker.internal:host-gateway \
    --tmpfs /tmp:exec \
    --security-opt=no-new-privileges:true \
    --cap-drop=ALL \
    opencode-sandbox:latest \
    "$@"
