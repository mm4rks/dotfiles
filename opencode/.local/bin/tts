#!/usr/bin/env python3
import sys
import os
import subprocess
import tempfile
import shutil

# Portable site-packages injection
venv_path = os.path.expanduser("~/.local/share/kokoro-env/lib/python3.11/site-packages")
if os.path.exists(venv_path):
    sys.path.insert(0, venv_path)

import scipy.io.wavfile as wavfile
from kokoro_onnx import Kokoro

def main():
    if len(sys.argv) < 2:
        print("Usage: tts <text> [voice]")
        sys.exit(1)

    text = sys.argv[1]
    voice = sys.argv[2] if len(sys.argv) > 2 else "af_bella"
    
    model_path = os.path.expanduser("~/.local/share/kokoro/kokoro-v0_19.onnx")
    voices_path = os.path.expanduser("~/.local/share/kokoro/voices.bin")
    
    if not os.path.exists(model_path):
        print(f"Error: Model not found at {model_path}")
        sys.exit(1)

    # Initialize Kokoro
    kokoro = Kokoro(model_path, voices_path)
    
    print(f"Speaking: '{text}' (Voice: {voice})")
    try:
        samples, sample_rate = kokoro.create(text, voice=voice, speed=1.0, lang="en-us")
        
        # Write to a temporary file
        with tempfile.NamedTemporaryFile(suffix=".wav", delete=False) as f:
            temp_path = f.name
            wavfile.write(temp_path, sample_rate, samples)
        
        # Determine player
        player = None
        if shutil.which("paplay"):
            player = "paplay"
        elif shutil.which("aplay"):
            player = "aplay -q"
        
        if player:
            # Play in background and cleanup immediately after playback
            # We use start_new_session=True to detach from the current process
            subprocess.Popen(
                f"{player} {temp_path} && rm {temp_path}",
                shell=True,
                start_new_session=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            )
        else:
            print("Error: Neither paplay nor aplay found.")
            if os.path.exists(temp_path):
                os.remove(temp_path)
            sys.exit(1)
                
    except Exception as e:
        print(f"Error during TTS generation: {e}")
        sys.exit(1)

if __name__ == "__main__":
    main()
