{
    "$schema": "https://opencode.ai/config.json",
    "autoupdate": false,
    "permission": {
        "external_directory": {
            "~/share": "allow",
            "~/share/**": "allow"
        }
    },
    "plugin": [
        "opencode-gemini-auth"
    ],
    "provider": {
        "google": {
            "name": "Google",
            "npm": "@ai-sdk/google"
        },
        "anthropic": {
            "name": "Anthropic",
            "npm": "@ai-sdk/anthropic"
        },
        "ollama": {
            "models": {
                "qwen3.5:2b-q4_K_M": {
                    "_launch": true,
                    "name": "qwen3.5:2b-q4_K_M"
                }
            },
            "name": "Ollama",
            "npm": "@ai-sdk/openai-compatible",
            "options": {
                "baseURL": "http://host.docker.internal:11434/v1"
            }
        }
    },
    "mcp": {
        "caldav": {
            "type": "local",
            "command": [
                "bash",
                "-c",
                "CALDAV_PASSWORD=\"$NEXTCLOUD_APP_PASSWORD\" npx -y caldav-mcp"
            ],
            "environment": {
                "CALDAV_BASE_URL": "https://nx16614.your-storageshare.de/remote.php/dav",
                "CALDAV_USERNAME": "agent"
            },
            "enabled": true
        }
    }
}
