java = "temurin-21"
"pipx:semgrep" = "1.76.0"
"pipx:flare-capa" = "8.0.1"
"pipx:apkleaks" = "latest"
"npm:@cyclonedx/cdxgen" = "latest"
# apktool installed by scripts/install_apktool.sh (jar + wrapper, incompatible with ubi)
# dependency-check installed by scripts/install_dependency_check.sh (zip release, incompatible with ubi/aqua)
# jadx installed by scripts/install_jadx.sh (zip release has no OS tag, incompatible with ubi/aqua)
# wireshark requires system installation: sudo apt install wireshark

