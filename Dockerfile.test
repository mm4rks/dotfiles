RUN chmod +x ./scripts/install_certipy.sh && ./scripts/install_certipy.sh

COPY --chown=tester:tester scripts/sync_nvim.sh ./scripts/sync_nvim.sh
RUN chmod +x ./scripts/sync_nvim.sh && ./scripts/sync_nvim.sh

# --- Kali Linux Guest (Sandbox) Test ---
FROM kalilinux/kali-rolling AS kali-guest-test
ARG DEBIAN_FRONTEND=noninteractive
RUN apt-get update && apt-get install -y sudo curl gpg wget && rm -rf /var/lib/apt/lists/*
RUN useradd -m -G sudo -s /bin/bash tester
RUN echo "tester ALL=(ALL) NOPASSWD: ALL" > /etc/sudoers.d/tester
# Note: We run with sudo in guest test for Phase 1 deps, but ensure no stow
USER tester
WORKDIR /home/tester/dotfiles
COPY --chown=tester:tester . .
# Run guest setup
RUN chmod +x ./scripts/*.sh ./setup.sh && ./setup.sh guest
# Verify no symlinks in $HOME (isolation check)
RUN [ ! -L /home/tester/.zshrc ]
RUN [ ! -L /home/tester/.tmux.conf ]
# Verify sandbox directories exist
RUN [ -d /home/tester/dotfiles/config ]
RUN [ -d /home/tester/dotfiles/zsh ]
RUN [ -d /home/tester/dotfiles/zsh/.zsh_completions ]
# Verify libatomic1 is installed (dependency check)
RUN dpkg -l | grep libatomic1
# Verify activate.sh works (basic check)
RUN bash -c "source ./activate.sh && [ \"\$ZDOTDIR\" = \"/home/tester/dotfiles/zsh\" ]"
# Verify fpath includes custom completions in sandbox
RUN zsh -c "source ./activate.sh && [[ \"\$fpath\" == */home/tester/dotfiles/zsh/.zsh_completions* ]]"

